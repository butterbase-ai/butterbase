# =============================================================================
# Butterbase Production Environment Variables
# =============================================================================
# This file documents every environment variable needed for production.
# Variables marked (secret) must be set via `fly secrets set` or `wrangler secret put`.
# Variables marked (fly.toml) are set in the fly.toml [env] block.
# =============================================================================

# ---------------------------------------------------------------------------
# Platform App -- Control API (Fly.io)
# ---------------------------------------------------------------------------

# (fly.toml)
NODE_ENV=production
CONTROL_API_PORT=4000
COGNITO_REGION=eu-north-1
AWS_REGION=auto
# Real AWS region for SES only (never "auto"). Must match where you verify identities in SES.
SES_REGION=us-east-1
S3_BUCKET_NAME=butterbase-storage
S3_ENDPOINT=https://<cf-account-id>.r2.cloudflarestorage.com
S3_PUBLIC_ENDPOINT=https://<cf-account-id>.r2.cloudflarestorage.com
S3_FORCE_PATH_STYLE=true
SES_FROM_EMAIL=noreply@butterbase.ai
SES_FROM_NAME=Butterbase
DENO_RUNTIME_URL=https://butterbase-runtime.fly.dev
CHECK_INTERVAL_MS=60000

# (secret) -- set via: fly secrets set -a butterbase-platform
CONTROL_DB_URL=postgresql://butterbase:<password>@ep-cool-forest-123456.us-east-1.aws.neon.tech/butterbase_control

# Multi-region Phase 1: Platform DB primary + standby
# In Phase 1, both URLs may point at the same DB if you have not yet provisioned a standby.
# The failover script swaps PLATFORM_DB_ACTIVE_SIDE and restarts processes.
NEON_PLATFORM_PRIMARY_URL=postgresql://butterbase:<password>@ep-cool-forest-123456.us-east-1.aws.neon.tech/butterbase_control
NEON_PLATFORM_STANDBY_URL=
PLATFORM_DB_ACTIVE_SIDE=primary

# Multi-region region identification (required at startup, no defaults).
# - In production on Fly, BUTTERBASE_REGION is set from FLY_REGION + BUTTERBASE_FLY_REGION_MAP.
BUTTERBASE_REGIONS=us-east-1,eu-west-1
# BUTTERBASE_REGION=          # leave unset in production; derived from FLY_REGION
BUTTERBASE_FLY_REGION_MAP=iad:us-east-1,lhr:eu-west-1

# Failover script secrets (set as Fly secrets, NOT in this file):
# NEON_PLATFORM_PROJECT_ID=<primary-neon-project-id>
# NEON_PLATFORM_STANDBY_PROJECT_ID=<standby-neon-project-id>
# PLATFORM_FLY_APPS=butterbase-platform

# Per-region runtime DB project IDs (one per region in BUTTERBASE_REGIONS).
# Required at startup. Each region's runtime DB holds the hot-path tables that
# customer apps read on every request (apps, app_users, app_oauth_*, etc.).
NEON_RUNTIME_PROJECT_ID_US_EAST_1=postgresql://butterbase:<password>@ep-runtime-us.us-east-1.aws.neon.tech/butterbase_runtime_us
NEON_RUNTIME_PROJECT_ID_EU_WEST_1=postgresql://butterbase:<password>@ep-runtime-eu.eu-west-1.aws.neon.tech/butterbase_runtime_eu

NEON_API_KEY=<neon-console-account-api-keys>
NEON_DATA_PROJECT_ID=<neonctl-projects-list>
# NEON_DATA_DATABASE_OWNER=butterbase
AUTH_ENCRYPTION_KEY=<openssl-rand-hex-32>
COGNITO_USER_POOL_ID=<from-aws-cognito>
COGNITO_CLIENT_ID=<from-aws-cognito>
# R2/S3 only (not SES)
AWS_ACCESS_KEY_ID=<from-r2-api-token>
AWS_SECRET_ACCESS_KEY=<from-r2-api-token>
SES_AWS_ACCESS_KEY_ID=<iam-user-with-ses-send-only>
SES_AWS_SECRET_ACCESS_KEY=<ses-iam-secret>
SENTRY_DSN=<from-sentry>
STRIPE_SECRET_KEY=<from-stripe-dashboard>
STRIPE_WEBHOOK_SECRET=<from-stripe-webhook-endpoint>
STRIPE_CONNECT_WEBHOOK_SECRET=<from-stripe-connect-webhook-endpoint>
REDIS_URL=<upstash-redis-url-or-fly-redis>
DASHBOARD_URL=https://dashboard.butterbase.ai
OPENROUTER_API_KEY=<from-openrouter-dashboard>

# ---------------------------------------------------------------------------
# Platform App -- Dashboard API (same Fly.io machine)
# ---------------------------------------------------------------------------

# (fly.toml)
DASHBOARD_API_PORT=4100
CONTROL_API_URL=http://localhost:4000

# (secret) -- shares same CONTROL_DB_* and COGNITO_* as Control API above

# ---------------------------------------------------------------------------
# Platform App -- Cron Scheduler (same Fly.io machine)
# ---------------------------------------------------------------------------

# (secret)
CONTROL_PLANE_URL=postgresql://butterbase:<password>@ep-cool-forest-123456.us-east-1.aws.neon.tech/butterbase_control?sslmode=require

# (fly.toml) -- DENO_RUNTIME_URL and CHECK_INTERVAL_MS shared with Control API above
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Runtime App -- Deno Runtime (Fly.io)
# ---------------------------------------------------------------------------

# (fly.toml)
PORT=7133
MAX_CONCURRENT_WORKERS=100
PGBOUNCER_PORT=6543

# (secret) -- set via: fly secrets set -a butterbase-runtime
# CONTROL_PLANE_URL=postgresql://butterbase:<password>@ep-cool-forest-123456.us-east-1.aws.neon.tech/butterbase_control?sslmode=require
# AUTH_ENCRYPTION_KEY=<same-key-as-platform>
# PGBOUNCER_HOST=ep-cool-forest-123456.us-east-1.aws.neon.tech
# PGBOUNCER_USER=butterbase
# PGBOUNCER_PASSWORD=<from-neon-console>

# ---------------------------------------------------------------------------
# Dashboard Frontend -- Cloudflare Pages (build-time)
# ---------------------------------------------------------------------------

# Set in Cloudflare Pages > Settings > Environment Variables
# VITE_DASHBOARD_API_URL=https://api.butterbase.ai
# VITE_CONTROL_API_URL=https://api.butterbase.ai
# VITE_COGNITO_USER_POOL_ID=eu-north-1_w3FLiuhYk
# VITE_COGNITO_CLIENT_ID=61e35nntfe...
# VITE_COGNITO_DOMAIN=eu-north-1w3fliuhyk.auth.eu-north-1.amazoncognito.com
# VITE_APP_URL=https://dashboard.butterbase.ai

# ---------------------------------------------------------------------------
# Storage Indexer -- Cloudflare Worker
# ---------------------------------------------------------------------------

# Set via: wrangler secret put NEON_DATABASE_URL
# NEON_DATABASE_URL=postgresql://butterbase:<password>@ep-cool-forest-123456.us-east-1.aws.neon.tech/butterbase_control?sslmode=require
# STORAGE_BUCKET binding is configured in wrangler.toml (not set manually)

# Phase 3: shared secret for region-to-region internal calls (lease grant) and
# cron-scheduler -> control-api calls (drain trigger, orphan cleanup).
# Rotate quarterly. Set the same value on every Fly app.
BUTTERBASE_INTERNAL_SECRET=change-me-in-production

# The region whose runtime DB is in the same Neon project as the platform DB.
# Other regions route lease-grant requests to this region's control-api.
BUTTERBASE_PLATFORM_REGION=us-east-1

# Phase 3: lease tuning
BUTTERBASE_LEASE_SIZE_USD=  # required: USD amount per lease grant
BUTTERBASE_LEASE_REFILL_THRESHOLD_USD=  # required: USD threshold below which a proactive refill is triggered
BUTTERBASE_LEASE_TTL_SECONDS=  # required: lease validity window in seconds
BUTTERBASE_LEASE_RECLAIM_GRACE_SECONDS=30
DEFAULT_FREE_PLAN_AI_CREDITS_USD=  # required: USD of AI credits included in the free plan
BUTTERBASE_OUTBOX_DRAIN_INTERVAL_MS=1000
BUTTERBASE_OUTBOX_LAG_ALERT_SECONDS=30

# URL of the control-api in BUTTERBASE_PLATFORM_REGION. Other regions call
# this for lease grants.
CONTROL_PLANE_URL_PLATFORM_REGION=http://control-api.us-east-1.internal:4000

# Phase 4: per-region Neon data project IDs.
NEON_DATA_PROJECT_ID_US_EAST_1=prod-data-use1

# Phase 5: move-app saga
MOVE_APP_DRIVER_ENABLED=true
MOVE_APP_STEP_TIMEOUT_SECONDS=1800
MOVE_APP_DUMP_BUCKET_US_EAST_1=butterbase-move-dumps-use1
MOVE_APP_DUMP_BUCKET_EU_WEST_1=butterbase-move-dumps-euw1

# AI Gateway Markup
AI_MARKUP_PERCENT=  # markup as percentage; set per your pricing strategy

# Suggestions Notification
SUGGESTIONS_NOTIFICATION_EMAIL=  # email for platform suggestions/feedback
