{
  "name": "@butterbase/shared",
  "version": "0.2.0",
  "description": "Shared types and constants for Butterbase packages",
  "license": "Apache-2.0",
  "homepage": "https://butterbase.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/NetGPT-Inc/butterbase-oss",
    "directory": "packages/shared"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./constants": {
      "import": "./dist/constants.js",
      "types": "./dist/constants.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./error-types": {
      "import": "./dist/error-types.js",
      "types": "./dist/error-types.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "vitest": "^3.2.4"
  }
}
