{
  "name": "@butterbase/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/create-server.js",
  "types": "./dist/create-server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/create-server.d.ts",
      "default": "./dist/create-server.js"
    },
    "./create-server": {
      "types": "./dist/create-server.d.ts",
      "default": "./dist/create-server.js"
    },
    "./request-auth-context": {
      "types": "./dist/request-auth-context.d.ts",
      "default": "./dist/request-auth-context.js"
    },
    "./api-client": {
      "types": "./dist/api-client.d.ts",
      "default": "./dist/api-client.js"
    }
  },
  "bin": {
    "butterbase-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -b --force",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "adm-zip": "^0.5.17",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  }
}
