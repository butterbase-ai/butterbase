{
  "name": "@butterbase/mcp",
  "version": "1.1.1",
  "description": "Butterbase MCP server — manage schemas, auth, functions, storage, RAG, realtime, and deploys on Butterbase from any MCP-capable client.",
  "license": "Apache-2.0",
  "homepage": "https://butterbase.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/butterbase-ai/butterbase.git",
    "directory": "services/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/butterbase-ai/butterbase/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "butterbase",
    "backend",
    "database",
    "auth",
    "serverless",
    "ai-agents"
  ],
  "mcpName": "io.github.butterbase-ai/mcp",
  "type": "module",
  "main": "./dist/create-server.js",
  "types": "./dist/create-server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/create-server.d.ts",
      "default": "./dist/create-server.js"
    },
    "./create-server": {
      "types": "./dist/create-server.d.ts",
      "default": "./dist/create-server.js"
    },
    "./request-auth-context": {
      "types": "./dist/request-auth-context.d.ts",
      "default": "./dist/request-auth-context.js"
    },
    "./api-client": {
      "types": "./dist/api-client.d.ts",
      "default": "./dist/api-client.js"
    }
  },
  "bin": {
    "butterbase-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b --force",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@butterbase/sdk": "^2.4.0",
    "@butterbase/shared": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "adm-zip": "^0.5.17",
    "pg": "^8.20.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  }
}
